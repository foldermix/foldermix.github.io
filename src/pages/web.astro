---
import Base from '../layouts/Base.astro';
const DEST = 'https://foldermix.shaypalachy.com/';
---
<Base title="foldermix Web" description="Jump straight to the browser upload flow.">
  <meta http-equiv="refresh" content={`0; url=${DEST}`} slot="head-extra" />
  <div class="splash">
    <div class="inner">
      <div class="logo-wrap">
        <span class="logo">fm</span>
        <span class="wordmark">foldermix</span>
        <span class="badge">web</span>
      </div>
      <p class="msg">Opening the browser upload flow…</p>
      <a href={DEST} class="btn">Go to Web →</a>
    </div>
  </div>
</Base>

<style>
  .splash {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(69,220,230,0.1) 0%, transparent 70%),
      #0d1117;
    text-align: center;
    padding: 24px;
  }
  .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }
  .logo-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo {
    background: linear-gradient(135deg, #45dce6, #7c6af7);
    color: #0d1117;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 3px 9px;
    border-radius: 5px;
    letter-spacing: 0.05em;
  }
  .wordmark {
    font-weight: 600;
    font-size: 1.1rem;
    color: #e6edf3;
  }
  .badge {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #45dce6;
    border: 1px solid rgba(69,220,230,0.35);
    border-radius: 999px;
    padding: 2px 10px;
  }
  .msg {
    color: #8b949e;
    font-size: 1rem;
    margin: 0;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    background: linear-gradient(135deg, #45dce6, #7c6af7);
    color: #0d1117;
    text-decoration: none;
    transition: opacity 0.15s, transform 0.1s;
  }
  .btn:hover { opacity: 0.88; transform: translateY(-1px); text-decoration: none; }
</style>

<script define:vars={{ DEST }}>
  window.location.replace(DEST);
</script>

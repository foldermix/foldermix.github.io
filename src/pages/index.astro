---
import Base from '../layouts/Base.astro';
---
<Base>
  <!-- NAV -->
  <header>
    <nav>
      <span class="logo">fm</span>
      <span class="wordmark">foldermix</span>
      <div class="nav-links">
        <a href="#cli">CLI</a>
        <a href="#desktop">Desktop</a>
        <a href="#web">Web</a>
        <a href="https://github.com/foldermix/foldermix" target="_blank" rel="noopener">GitHub</a>
      </div>
    </nav>
  </header>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="badge">open source · MIT</div>
      <h1>Pack any folder.<br/><span class="accent">LLM-ready</span> in seconds.</h1>
      <p class="hero-sub">
        foldermix bundles a local directory into a single context file you can
        drop straight into ChatGPT, Claude, Gemini, or any other LLM.
        Pick your workflow — CLI, native desktop app, or the web.
      </p>
      <div class="trio-row">
        <div class="trio">
          <a href="#cli" class="trio-item">
            <span class="trio-icon">⌨️</span>
            <span class="trio-label">CLI</span>
          </a>
          <span class="trio-sep"></span>
          <a href="#desktop" class="trio-item">
            <span class="trio-icon">🖥️</span>
            <span class="trio-label">Desktop</span>
          </a>
          <span class="trio-sep"></span>
          <a href="#web" class="trio-item trio-soon">
            <span class="trio-icon">🌐</span>
            <span class="trio-label">Web</span>
            <span class="trio-soon-pill">soon</span>
          </a>
        </div>
        <a href="https://github.com/foldermix/foldermix" class="gh-pill" target="_blank" rel="noopener" aria-label="GitHub">
          <svg height="18" width="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
      </div>
      <div class="terminal">
        <div class="terminal-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
          <span class="terminal-title">bash</span>
        </div>
        <pre class="terminal-body"><span class="prompt">$</span> pip install foldermix
<span class="prompt">$</span> foldermix pack ./my-project --out context.md
<span class="out">Scanning ./my-project ...</span>
<span class="out">42 files matched • 3 files skipped</span>
<span class="green-text">Pack complete: 42 files, 1.2 MB → context.md</span></pre>
      </div>
    </div>
  </section>

  <!-- CLI -->
  <section class="product" id="cli">
    <div class="container">
      <div class="product-header">
        <div class="product-icon">⌨️</div>
        <div>
          <h2>foldermix CLI</h2>
          <p class="product-sub">The fastest way to pack. Scriptable, pipeable, CI-friendly.</p>
        </div>
      </div>
      <div class="features">
        <div class="feature">
          <div class="feature-title">Multiple output formats</div>
          <div class="feature-desc">Markdown, XML, or JSONL — whatever your LLM prefers.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Smart filtering</div>
          <div class="feature-desc">Gitignore-aware, extension filters, glob patterns, size limits.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Office &amp; PDF conversion</div>
          <div class="feature-desc">Converts .docx, .xlsx, .pptx, and PDFs (with optional OCR) into readable text.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Policy checks</div>
          <div class="feature-desc">Scan for secrets and sensitive patterns before you share.</div>
        </div>
      </div>
      <div class="install-block">
        <div class="install-label">Install</div>
        <div class="install-options">
          <div class="install-option">
            <span class="install-via">pip</span>
            <code>pip install foldermix</code>
          </div>
          <div class="install-option">
            <span class="install-via">brew</span>
            <code>brew install foldermix/tap/foldermix</code>
          </div>
        </div>
        <div class="install-cta">
          <a href="https://github.com/foldermix/foldermix" class="btn btn-primary" target="_blank" rel="noopener">
            CLI docs &amp; source →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- DESKTOP -->
  <section class="product alt" id="desktop">
    <div class="container">
      <div class="product-header">
        <div class="product-icon">🖥️</div>
        <div>
          <h2>foldermix Desktop</h2>
          <p class="product-sub">Native macOS app. Point, click, pack.</p>
        </div>
      </div>
      <div class="features">
        <div class="feature">
          <div class="feature-title">Visual file preview</div>
          <div class="feature-desc">See exactly which files will be included before you pack.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Extension picker</div>
          <div class="feature-desc">Check or uncheck file types detected in your folder. Add custom extensions.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Live log pane</div>
          <div class="feature-desc">Terminal-style output with ANSI colour rendered right in the app.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Self-contained bundle</div>
          <div class="feature-desc">No Python install required. The CLI is bundled inside the DMG.</div>
        </div>
      </div>
      <div class="install-block">
        <div class="install-label">Download — macOS (Apple Silicon &amp; Intel)</div>
        <div class="install-cta">
          <a
            href="https://github.com/foldermix/foldermix-desktop/releases/latest/download/foldermix-desktop.dmg"
            class="btn btn-primary"
          >
            Download <span class="dl-size">~35 MB</span> →
          </a>
          <a
            href="https://github.com/foldermix/foldermix-desktop/releases/latest/download/foldermix-desktop-full.dmg"
            class="btn btn-ghost"
          >
            with OCR <span class="dl-size">~130 MB</span> →
          </a>
          <a
            href="https://github.com/foldermix/foldermix-desktop"
            class="btn btn-ghost"
            target="_blank"
            rel="noopener"
          >
            Source
          </a>
        </div>
        <p class="install-note">
          macOS 13 Ventura or later · Ad-hoc signed · right-click → Open on first launch<br/>
          The OCR build adds support for scanned &amp; image-only PDFs (~95 MB of ML models).
        </p>
      </div>
    </div>
  </section>

  <!-- WEB (coming soon) -->
  <section class="product" id="web">
    <div class="container">
      <div class="product-header">
        <div class="product-icon">🌐</div>
        <div>
          <h2>foldermix Web <span class="coming-soon">coming soon</span></h2>
          <p class="product-sub">Pack directly in your browser. No install, no setup.</p>
        </div>
      </div>
      <div class="features muted">
        <div class="feature">
          <div class="feature-title">Drag &amp; drop</div>
          <div class="feature-desc">Drop a folder straight onto the page.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Instant preview</div>
          <div class="feature-desc">See the output before downloading.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Zero upload</div>
          <div class="feature-desc">Everything runs client-side. Your files never leave your machine.</div>
        </div>
        <div class="feature">
          <div class="feature-title">Copy to clipboard</div>
          <div class="feature-desc">One click to copy the packed context and paste into any LLM chat.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="container footer-inner">
      <span class="footer-brand">foldermix</span>
      <span class="footer-copy">MIT licence · built by <a href="https://github.com/shaypal5" target="_blank" rel="noopener">@shaypal5</a></span>
      <div class="footer-links">
        <a href="https://github.com/foldermix/foldermix" target="_blank" rel="noopener">CLI</a>
        <a href="https://github.com/foldermix/foldermix-desktop" target="_blank" rel="noopener">Desktop</a>
        <a href="https://github.com/foldermix" target="_blank" rel="noopener">GitHub org</a>
      </div>
    </div>
  </footer>
</Base>

<style>
  /* TRIO */
  .trio-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-bottom: 40px;
  }
  .trio {
    display: flex;
    align-items: center;
    gap: 0;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 6px 8px;
  }
  .gh-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    transition: color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .gh-pill:hover {
    color: var(--text);
    background: rgba(255,255,255,0.08);
    text-decoration: none;
  }
  .trio-item {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5px 18px;
    border-radius: 999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.15s, background 0.15s;
    text-decoration: none;
  }
  .trio-item:hover {
    color: var(--text);
    background: rgba(255,255,255,0.06);
    text-decoration: none;
  }
  .trio-icon { font-size: 1rem; line-height: 1; }
  .trio-sep {
    width: 1px;
    height: 18px;
    background: var(--border);
    flex-shrink: 0;
  }
  .trio-soon { opacity: 0.55; }
  .trio-soon-pill {
    font-size: 0.6rem;
    font-family: var(--mono);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--accent2);
    background: rgba(124,106,247,0.12);
    border: 1px solid rgba(124,106,247,0.25);
    border-radius: 999px;
    padding: 1px 6px;
  }

  /* NAV */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(13,17,23,0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .logo {
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #0d1117;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 3px 8px;
    border-radius: 5px;
    letter-spacing: 0.05em;
  }
  .wordmark {
    font-weight: 600;
    font-size: 1rem;
    color: var(--text);
    margin-right: auto;
  }
  .nav-links { display: flex; gap: 28px; }
  .nav-links a { color: var(--muted); font-size: 0.9rem; transition: color 0.15s; }
  .nav-links a:hover { color: var(--text); text-decoration: none; }

  /* HERO */
  .hero {
    padding: 100px 24px 80px;
    text-align: center;
    background:
      radial-gradient(ellipse 70% 50% at 50% -10%, rgba(69,220,230,0.12) 0%, transparent 70%),
      var(--bg);
  }
  .hero-inner { max-width: 760px; margin: 0 auto; }
  .badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--accent);
    border: 1px solid rgba(69,220,230,0.3);
    border-radius: 999px;
    padding: 3px 14px;
    margin-bottom: 28px;
  }
  h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }
  .accent { color: var(--accent); }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 580px;
    margin: 0 auto 36px;
    line-height: 1.7;
  }
  .hero-actions { display: none; }

  /* BUTTONS */
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 10px 22px;
    border-radius: var(--radius);
    font-size: 0.95rem;
    font-weight: 600;
    transition: opacity 0.15s, transform 0.1s;
  }
  .btn:hover { opacity: 0.88; text-decoration: none; transform: translateY(-1px); }
  .btn-primary { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #0d1117; }
  .btn-ghost   { border: 1px solid var(--border); color: var(--text); background: transparent; }

  /* TERMINAL */
  .terminal {
    background: #010409;
    border: 1px solid var(--border);
    border-radius: 10px;
    text-align: left;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }
  .terminal-bar {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .dot { width: 12px; height: 12px; border-radius: 50%; }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green  { background: #28c840; }
  .terminal-title { font-size: 0.8rem; color: var(--muted); font-family: var(--mono); margin-left: 8px; }
  .terminal-body {
    padding: 20px 24px;
    font-size: 0.88rem;
    line-height: 1.9;
    white-space: pre;
    overflow-x: auto;
  }
  .prompt     { color: var(--accent); user-select: none; }
  .out        { color: var(--muted); }
  .green-text { color: var(--green); }

  /* PRODUCTS */
  .product { padding: 80px 24px; }
  .product.alt { background: var(--surface); }
  .container { max-width: 1000px; margin: 0 auto; }

  .product-header { display: flex; align-items: flex-start; gap: 20px; margin-bottom: 40px; }
  .product-icon { font-size: 2.4rem; line-height: 1; padding-top: 2px; }

  h2 { font-size: 1.8rem; font-weight: 700; margin-bottom: 6px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .product-sub { color: var(--muted); font-size: 1rem; }

  .coming-soon {
    font-size: 0.65rem;
    font-weight: 600;
    font-family: var(--mono);
    background: rgba(124,106,247,0.15);
    color: var(--accent2);
    border: 1px solid rgba(124,106,247,0.35);
    border-radius: 999px;
    padding: 2px 10px;
    vertical-align: middle;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 40px;
  }
  .features.muted .feature { opacity: 0.45; }
  .feature {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 20px;
  }
  .product.alt .feature { background: var(--bg); }
  .feature-title { font-weight: 600; font-size: 0.95rem; margin-bottom: 6px; }
  .feature-desc  { font-size: 0.875rem; color: var(--muted); line-height: 1.55; }

  .install-block {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 28px;
  }
  .product.alt .install-block { background: var(--surface); border-color: var(--border); }
  .install-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 14px;
  }
  .install-options { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
  .install-option  { display: flex; align-items: center; gap: 12px; }
  .install-via {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
    background: rgba(69,220,230,0.08);
    border: 1px solid rgba(69,220,230,0.2);
    border-radius: 4px;
    padding: 2px 8px;
    width: 44px;
    text-align: center;
    flex-shrink: 0;
  }
  code {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 4px 10px;
    color: var(--text);
  }
  .install-cta   { display: flex; gap: 12px; flex-wrap: wrap; }
  .install-note  { margin-top: 14px; font-size: 0.8rem; color: var(--muted); line-height: 1.6; }
  .dl-size { opacity: 0.7; font-weight: 400; font-size: 0.8em; }

  /* FOOTER */
  footer { border-top: 1px solid var(--border); padding: 28px 24px; }
  .footer-inner { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .footer-brand { font-family: var(--mono); font-weight: 700; color: var(--accent); }
  .footer-copy  { font-size: 0.85rem; color: var(--muted); margin-right: auto; }
  .footer-links { display: flex; gap: 20px; }
  .footer-links a { font-size: 0.85rem; color: var(--muted); }
  .footer-links a:hover { color: var(--text); text-decoration: none; }

  @media (max-width: 600px) {
    .nav-links { gap: 16px; }
    .product-header { flex-direction: column; gap: 10px; }
    .footer-inner { flex-direction: column; align-items: flex-start; }
    .footer-copy { margin-right: 0; }
  }
</style>
